{
  "name": "Savings Plan coverage",
  "clock": {
    "start": "2026-02-01"
  },
  "organization_template": "anycompany-retail",
  "random_seed": 64,
  "events": [
    {
      "id": "create-storefront-compute-sp",
      "day": 1,
      "action": "create_savings_plan",
      "payer_account": "Management",
      "owner_account": "Storefront Prod",
      "usage_type": "instance-hours:t3.medium",
      "region": "us-east-1",
      "sharing_scope": "organization",
      "term_start_at": "2026-02-01T00:00:00Z",
      "term_end_at": "2026-02-01T03:00:00Z",
      "hourly_commitment_micros": 100000,
      "upfront_fee_micros": 90000,
      "description": "Shared Storefront compute Savings Plan"
    },
    {
      "id": "create-storefront-web-sp-lab",
      "day": 1,
      "action": "create_resource",
      "account": "Storefront Prod",
      "service": "Amazon EC2",
      "resource": "storefront-sp-web",
      "resource_type": "ec2_instance",
      "region": "us-east-1",
      "tags": {
        "app": "storefront",
        "env": "prod",
        "owner": "storefront-team"
      },
      "attributes": {
        "instance_type": "t3.medium"
      }
    },
    {
      "id": "create-analytics-worker-sp-lab",
      "day": 1,
      "action": "create_resource",
      "account": "Analytics Prod",
      "service": "Amazon EC2",
      "resource": "analytics-sp-worker",
      "resource_type": "ec2_instance",
      "region": "us-east-1",
      "tags": {
        "app": "analytics",
        "env": "prod",
        "owner": "analytics-team"
      },
      "attributes": {
        "instance_type": "t3.medium"
      }
    },
    {
      "id": "storefront-covered-hours",
      "day": 1,
      "action": "add_usage",
      "account": "Storefront Prod",
      "service": "Amazon EC2",
      "resource": "storefront-sp-web",
      "usage_start_at": "2026-02-01T00:00:00Z",
      "usage_end_at": "2026-02-01T02:00:00Z",
      "amount_hours": 2
    },
    {
      "id": "analytics-shared-covered-hours",
      "day": 1,
      "action": "add_usage",
      "account": "Analytics Prod",
      "service": "Amazon EC2",
      "resource": "analytics-sp-worker",
      "usage_start_at": "2026-02-01T00:00:00Z",
      "usage_end_at": "2026-02-01T02:00:00Z",
      "amount_hours": 2
    },
    {
      "id": "meter-savings-plan-coverage",
      "day": 2,
      "action": "run_daily_metering",
      "payer_account": "Management"
    }
  ]
}
